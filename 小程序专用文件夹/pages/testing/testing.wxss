.section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.steps-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  position: relative;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.steps-line {
  position: absolute;
  left: 55rpx;
  top: 100rpx;
  bottom: 100rpx;
  width: 4rpx;
  background-color: #E8F8F8;
}

.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-circle {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: #00A6A6;
  color: #ffffff;
  font-size: 16px;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
  padding-top: 8rpx;
}

.step-title {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 6rpx;
}

.step-desc {
  font-size: 13px;
  color: #888888;
}

.method-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.method-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.method-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.method-name {
  font-size: 17px;
  font-weight: bold;
  color: #00A6A6;
}

.method-desc {
  font-size: 15px;
  color: #333333;
  margin-bottom: 12rpx;
}

.method-detail {
  font-size: 13px;
  color: #666666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.method-suitable {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.suitable-text {
  font-size: 13px;
  color: #333333;
  margin-left: 12rpx;
}

.screening-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.screening-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.screening-item:last-child {
  border-bottom: none;
}

.screening-age {
  width: 160rpx;
  font-size: 15px;
  font-weight: bold;
  color: #00A6A6;
}

.screening-info {
  flex: 1;
}

.screening-method {
  font-size: 14px;
  color: #333333;
  margin-bottom: 6rpx;
}

.screening-interval {
  font-size: 13px;
  color: #888888;
}

.report-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.report-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.report-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.report-title {
  font-size: 16px;
  font-weight: bold;
  color: #333333;
}

.report-result {
  background-color: #E8F8F8;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.report-result.negative {
  background-color: #E8F8F8;
  border-left: 6rpx solid #00A6A6;
}

.report-result.positive {
  background-color: #FFF5F7;
  border-left: 6rpx solid #FFB6C1;
}

.result-label {
  font-size: 12px;
  color: #888888;
  margin-bottom: 10rpx;
}

.result-value {
  font-size: 14px;
  color: #333333;
  margin-bottom: 6rpx;
}

.report-interpretation {
  margin-bottom: 20rpx;
}

.interpretation-title {
  font-size: 14px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
}

.interpretation-text {
  font-size: 14px;
  color: #666666;
  line-height: 1.6;
}

.report-advice {
  display: flex;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.advice-text {
  font-size: 14px;
  color: #333333;
  margin-left: 12rpx;
}