page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Helvetica Neue', Arial, sans-serif;
  font-size: 16px;
  line-height: 1.6;
  color: #333333;
  background-color: #ffffff;
}

.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

.primary-color {
  color: #00A6A6;
}

.primary-bg {
  background-color: #00A6A6;
}

.secondary-color {
  color: #FFB6C1;
}

.secondary-bg {
  background-color: #FFB6C1;
}

.white-bg {
  background-color: #ffffff;
}

.gray-text {
  color: #999999;
  font-size: 14px;
}

.light-gray-bg {
  background-color: #f5f5f5;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 18px;
  font-weight: bold;
  color: #00A6A6;
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #00A6A6;
}

.title {
  font-size: 20px;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 14px;
  color: #666666;
  margin-bottom: 20rpx;
}

.content {
  font-size: 16px;
  line-height: 1.8;
  color: #333333;
  text-align: justify;
}

.content-p {
  margin-bottom: 16rpx;
}

.bold-text {
  font-weight: bold;
}

.highlight-box {
  background-color: #E8F8F8;
  border-left: 6rpx solid #00A6A6;
  padding: 20rpx;
  margin: 20rpx 0;
  border-radius: 8rpx;
}

.pink-highlight-box {
  background-color: #FFF5F7;
  border-left: 6rpx solid #FFB6C1;
  padding: 20rpx;
  margin: 20rpx 0;
  border-radius: 8rpx;
}

.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  background-color: #E8F8F8;
  color: #00A6A6;
  border-radius: 20rpx;
  font-size: 12px;
  margin: 8rpx 8rpx 8rpx 0;
}

.pink-tag {
  background-color: #FFF5F7;
  color: #E8899A;
}

.btn {
  background-color: #00A6A6;
  color: #ffffff;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 16px;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 166, 166, 0.3);
}

.btn:active {
  opacity: 0.8;
}

.btn-outline {
  background-color: #ffffff;
  color: #00A6A6;
  border: 2rpx solid #00A6A6;
  box-shadow: none;
}

.flex {
  display: flex;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-between {
  justify-content: space-between;
}

.flex-center {
  align-items: center;
  justify-content: center;
}

.flex-col {
  flex-direction: column;
}

.flex-1 {
  flex: 1;
}

.text-center {
  text-align: center;
}

.mt-10 {
  margin-top: 10rpx;
}

.mt-20 {
  margin-top: 20rpx;
}

.mt-30 {
  margin-top: 30rpx;
}

.mb-10 {
  margin-bottom: 10rpx;
}

.mb-20 {
  margin-bottom: 20rpx;
}

.mb-30 {
  margin-bottom: 30rpx;
}

.ml-10 {
  margin-left: 10rpx;
}

.mr-10 {
  margin-right: 10rpx;
}

.pl-20 {
  padding-left: 20rpx;
}

.pr-20 {
  padding-right: 20rpx;
}

.divider {
  height: 1rpx;
  background-color: #EEEEEE;
  margin: 20rpx 0;
}

.icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #E8F8F8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #00A6A6;
  font-size: 36rpx;
}

.list-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.list-item:last-child {
  border-bottom: none;
}

.arrow-right::after {
  content: '>';
  color: #CCCCCC;
  font-size: 14px;
}

.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}